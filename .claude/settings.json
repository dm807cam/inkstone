{
  "//": "Permission allowlist for the improvement loop. CLAUDE.md is the primary guardrail; these deny rules are defense-in-depth. Verify rule syntax against current Claude Code docs for your version.",
  "permissions": {
    "deny": [
      "Edit(.github/**)",
      "Edit(.claude/**)",
      "Edit(CLAUDE.md)",
      "Edit(improvement/config.yml)",
      "Bash(git push origin main*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git rebase*)",
      "Bash(rm -rf*)"
    ],
    "ask": [
      "Bash(npm install*)",
      "Bash(npm i *)",
      "Bash(pip install*)",
      "Bash(yarn add*)",
      "Bash(npx *)"
    ]
  }
}
